# ========================================
# NEUROTASK - VARIÁVEIS DE AMBIENTE
# ========================================
# Copie este arquivo para .env e configure as variáveis
# NUNCA commite o arquivo .env com credenciais reais!

# ========================================
# DATABASE (MySQL)
# ========================================
DB_URL=jdbc:mysql://localhost:3306/neurotask?createDatabaseIfNotExist=true&serverTimezone=UTC
DB_USERNAME=root
DB_PASSWORD=sua-senha-aqui

# ========================================
# JWT CONFIGURATION
# ========================================
# Chave secreta para assinatura JWT (mínimo 32 caracteres)
# Gere uma chave forte com: openssl rand -base64 64
JWT_SECRET=sua-chave-secreta-jwt-aqui-minimo-32-caracteres
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# ========================================
# CORS CONFIGURATION
# ========================================
# Origens permitidas (separadas por vírgula)
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://localhost:3000

# ========================================
# MAIL CONFIGURATION (Gmail exemplo)
# ========================================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=seu-email@gmail.com
MAIL_PASSWORD=sua-app-password

# ========================================
# AI API CONFIGURATION (OpenAI/Groq)
# ========================================
OPENAI_API_KEY=sua-api-key-aqui
OPENAI_MODEL=llama-3.3-70b-versatile
OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=2048

# ========================================
# LOGGING
# ========================================
LOG_LEVEL=INFO
SHOW_SQL=false
HIBERNATE_SQL_LOG_LEVEL=OFF

# ========================================
# SERVER
# ========================================
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=dev